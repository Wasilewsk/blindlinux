#!/bin/bash
# ─── Blinbuntu Welcome Application ────────────────────────────────────────────
# First-boot welcome wizard for Blinbuntu.
# Provides optional package installation and accessibility setup.
# ───────────────────────────────────────────────────────────────────────────────

set -e

CONFIG_DIR="/var/lib/blinbuntu"
WELCOME_STATE="${CONFIG_DIR}/welcome-shown"
mkdir -p "${CONFIG_DIR}"

# Only show welcome once
if [ -f "${WELCOME_STATE}" ]; then
    # Still allow running via menu entry
    if [ "${1:-}" != "--force" ]; then
        exit 0
    fi
fi

# Check for zenity
if ! command -v zenity &>/dev/null; then
    echo "Welcome to Blinbuntu!"
    echo "Run 'blinbuntu-select-packages' to install optional software."
    echo "Run 'blinbuntu-toggle-screenreader' to toggle the screenreader."
    exit 0
fi

# ── Welcome Dialog ────────────────────────────────────────────────────────────
zenity --question \
    --title="Welcome to Blinbuntu" \
    --text="Welcome to Blinbuntu!\n\nThis is an accessible Linux distribution designed for everyone.\n\nWould you like to configure optional software now?" \
    --width=500 \
    --ok-label="Yes, Configure" \
    --cancel-label="Skip" \
    2>/dev/null

if [ $? -eq 0 ]; then
    # Run the optional package selector
    /usr/bin/blinbuntu-select-packages
fi

# ── Accessibility Setup ───────────────────────────────────────────────────────
zenity --question \
    --title="Accessibility Setup" \
    --text="Would you like to enable accessibility features?\n\nThis includes:\n- High contrast theme\n- Large fonts\n- Screen reader (Cthulhu)\n- Console screen reader (Fenrir)" \
    --width=500 \
    --ok-label="Enable Accessibility" \
    --cancel-label="Use Defaults" \
    2>/dev/null

if [ $? -eq 0 ]; then
    # Enable accessibility features
    gsettings set org.gnome.desktop/a11y always-show-text-cursor true 2>/dev/null || true
    gsettings set org.gnome/desktop/a11y/gtk high-contrast true 2>/dev/null || true
    gsettings set org.mate/desktop/interface gtk-theme 'HighContrast' 2>/dev/null || true
    gsettings set org.mate/desktop/interface icon-theme 'HighContrast' 2>/dev/null || true
    gsettings set org.mate/desktop/interface font-name 'Liberation Sans 12' 2>/dev/null || true

    # Start screenreader
    if command -v cthulhu &>/dev/null; then
        cthulhu &
    elif command -v orca &>/dev/null; then
        orca &
    fi
fi

# Mark welcome as shown
touch "${WELCOME_STATE}"
