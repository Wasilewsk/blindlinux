#!/bin/bash
set -e
# ─── Blinbuntu Post-Installation Script ───────────────────────────────────────
# Runs via Calamares after installation completes.
# Sets up the installed system with proper configuration.
# ───────────────────────────────────────────────────────────────────────────────

echo "[blinbuntu] Running post-installation configuration..."

# ── Remove live environment artifacts ─────────────────────────────────────────
rm -f /.blinbuntu-live
rm -f /tmp/.fenrir-autostarted 2>/dev/null || true

# ── Fix systemd services for installed system ─────────────────────────────────
# Re-enable services for the installed system
systemctl enable blinbuntu-startup-sound.service 2>/dev/null || true
systemctl enable blinbuntu-login-sound.service 2>/dev/null || true

# Remove the live sound service (not needed in installed system)
systemctl disable blinbuntu-live-sound.service 2>/dev/null || true

# ── Configure automatic security updates ──────────────────────────────────────
apt-get install -y unattended-upgrades 2>/dev/null || true
dpkg-reconfigure -plow unattended-upgrades 2>/dev/null || true

# ── Update locate database ────────────────────────────────────────────────────
update-locale 2>/dev/null || true

# ── Ensure proper permissions ─────────────────────────────────────────────────
chmod +x /usr/bin/blinbuntu-play-startup 2>/dev/null || true
chmod +x /usr/bin/blinbuntu-play-login 2>/dev/null || true
chmod +x /usr/bin/blinbuntu-play-live 2>/dev/null || true
chmod +x /usr/bin/blinbuntu-toggle-screenreader 2>/dev/null || true
chmod +x /usr/bin/blinbuntu-select-packages 2>/dev/null || true

# ── Update initramfs ──────────────────────────────────────────────────────────
update-initramfs -u 2>/dev/null || true

# ── Update GRUB ───────────────────────────────────────────────────────────────
update-grub 2>/dev/null || true

# ── Enable accessibility services ─────────────────────────────────────────────
# Ensure speech-dispatcher is enabled
systemctl enable speech-dispatcher.service 2>/dev/null || true

echo "[blinbuntu] Post-installation configuration complete."
echo "[blinbuntu] Welcome to Blinbuntu!"
