#!/bin/bash
# ─── Blinbuntu Package Selector ───────────────────────────────────────────────
# Interactive script to select and install optional packages.
# Used both during installation and after first boot.
# ───────────────────────────────────────────────────────────────────────────────

set -e

SELECTOR_STATE="/var/lib/blinbuntu/optional-packages"
mkdir -p "$(dirname "${SELECTOR_STATE}")"

# Package definitions
declare -A PACKAGES
PACKAGES[wine]="wine wine32 wine64 winetricks"
PACKAGES[portabop]=""

# Check if zenity is available, fall back to terminal
if command -v zenity &>/dev/null; then
    USE_GUI=true
else
    USE_GUI=false
fi

show_gui_selector() {
    local selected=""

    # Wine checkbox
    wine_check="FALSE"

    # Porta-Bop checkbox (only if not already installed)
    portabop_check="FALSE"
    if ! command -v portabop &>/dev/null && [ ! -f /opt/portabop/portabop ]; then
        portabop_check="TRUE"
    fi

    selected=$(zenity --list \
        --title="Blinbuntu - Optional Software" \
        --text="Select additional software to install:" \
        --checklist \
        --column="Install" \
        --column="Package" \
        --column="Description" \
        --width=600 \
        --height=300 \
        "${wine_check}" "wine" "Wine - Run Windows applications" \
        "${portabop_check}" "portabop" "Porta-Bop - Music rhythm game" \
        2>/dev/null) || return 0

    echo "${selected}"
}

show_terminal_selector() {
    echo ""
    echo "╔══════════════════════════════════════════════════╗"
    echo "║      Blinbuntu - Optional Software Selector     ║"
    echo "╠══════════════════════════════════════════════════╣"
    echo "║  Select additional software to install.         ║"
    echo "║  Enter the numbers separated by spaces.         ║"
    echo "╚══════════════════════════════════════════════════╝"
    echo ""
    echo "  [1] Wine - Run Windows applications"
    echo "  [2] Porta-Bop - Music rhythm game"
    echo ""
    read -rp "  Enter selections (e.g. '1 2' or 'none'): " selections
    echo "${selections}"
}

install_wine() {
    echo "[blinbuntu] Installing Wine..."
    dpkg --add-architecture i386 2>/dev/null || true
    apt-get update
    apt-get install -y wine wine32 wine64 winetricks 2>/dev/null || {
        echo "[blinbuntu] Wine installation failed. Trying minimal wine..."
        apt-get install -y wine64 2>/dev/null || {
            echo "[blinbuntu] ERROR: Could not install Wine."
            return 1
        }
    }
    echo "[blinbuntu] Wine installed successfully."
    return 0
}

install_portabop() {
    echo "[blinbuntu] Installing Porta-Bop..."

    local tarball="/usr/share/blinbuntu/portabop.tar.gz"
    local install_dir="/opt/portabop"

    if [ -f /usr/bin/portabop ]; then
        echo "[blinbuntu] Porta-Bop is already installed."
        return 0
    fi

    if [ ! -f "${tarball}" ]; then
        echo "[blinbuntu] ERROR: Porta-Bop installer not found."
        return 1
    fi

    mkdir -p "${install_dir}"
    cd "${install_dir}"
    tar -xzf "${tarball}" 2>/dev/null || {
        echo "[blinbuntu] ERROR: Failed to extract Porta-Bop."
        return 1
    }

    # Find and set up executable
    local bin=""
    for f in portabop Porta-Bop start.sh run.sh; do
        if [ -f "${f}" ] && [ -x "${f}" ]; then
            bin="${install_dir}/${f}"
            break
        fi
    done

    if [ -z "${bin}" ]; then
        bin=$(find . -maxdepth 1 -type f -executable 2>/dev/null | head -1)
    fi

    if [ -n "${bin}" ]; then
        cat > /usr/bin/portabop << WRAPPER
#!/bin/bash
cd "${install_dir}"
exec "${bin}" "\$@"
WRAPPER
        chmod +x /usr/bin/portabop
        echo "[blinbuntu] Porta-Bop installed successfully."
    fi

    return 0
}

# ── Main ──────────────────────────────────────────────────────────────────────

echo "[blinbuntu] Starting optional package selector..."

if [ "${USE_GUI}" = true ]; then
    selections=$(show_gui_selector)
else
    selections=$(show_terminal_selector)
fi

# Parse selections
if [ -z "${selections}" ] || echo "${selections}" | grep -qi "none"; then
    echo "[blinbuntu] No optional packages selected."
    echo "none" > "${SELECTOR_STATE}"
    exit 0
fi

echo "${selections}" > "${SELECTOR_STATE}"

# Install selected packages
if echo "${selections}" | grep -q "wine"; then
    install_wine
fi

if echo "${selections}" | grep -q "portabop"; then
    install_portabop
fi

echo "[blinbuntu] Optional package installation complete."
echo "[blinbuntu] You can re-run this selector anytime with: blinbuntu-select-packages"
